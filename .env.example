# ─── Required ─────────────────────────────────────────────────────────────────
APP_NAME="My Statamic Site"
APP_ENV=production
APP_DEBUG=false
APP_URL=                        # Set to your Railway public domain after first deploy

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# ─── APP_KEY ──────────────────────────────────────────────────────────────────
# IMPORTANT: Railway's ${{secret(32)}} does NOT produce a valid Laravel key.
# On first deploy, the container auto-generates a key and prints it to logs:
#   "ACTION REQUIRED: Copy this into Railway Variables: APP_KEY=base64:..."
# Copy that value here. Leave blank if using auto-generation.
APP_KEY=

# ─── Cache & Sessions ─────────────────────────────────────────────────────────
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

# ─── Statamic ─────────────────────────────────────────────────────────────────
STATAMIC_LICENSE_KEY=           # Optional: required for Pro features only
STATAMIC_STACHE_WATCHER=false   # Disable in production (filesystem watcher)
STATAMIC_STATIC_CACHING_STRATEGY=null
STATAMIC_REVISIONS_ENABLED=false
STATAMIC_GRAPHQL_ENABLED=false
STATAMIC_API_ENABLED=false
STATAMIC_GIT_ENABLED=false

# ─── First User Setup (optional — auto-creates super user on first deploy) ────
# If both are set, a super user is created automatically on first boot.
# ⚠️  REMOVE THESE VARS after the first user is created. The password is visible
#     to anyone with Railway dashboard access while it's set here.
STATAMIC_SUPER_USER_EMAIL=
STATAMIC_SUPER_USER_PASSWORD=
STATAMIC_SUPER_USER_NAME=Admin

# ─── Mail (optional) ──────────────────────────────────────────────────────────
# Default: log driver (emails go to container logs). Configure SMTP for real mail.
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stderr
LOG_LEVEL=error

# ─── Database (not used by default — Statamic uses flat-file storage) ─────────
DB_CONNECTION=sqlite
FILESYSTEM_DISK=local
